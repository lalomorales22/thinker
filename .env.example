# Thinker configuration. Copy to backend/.env (or export in your shell).

# Tinker API key — needed to train or chat for real. Get one at
# https://tinker-docs.thinkingmachines.ai/ . You can also add it in the app's
# Settings instead. Leave blank to explore in Demo mode.
TINKER_API_KEY=

# Ollama (optional) — powers the conversational training assistant.
# Install from https://ollama.ai and run e.g. `ollama pull llama3.2`.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Optional: where Thinker stores its SQLite DB + dataset files
# (defaults to backend/storage).
# THINKER_DATA_DIR=
